  "data_models": {
    "User": {
      "collection": "users",
      "fields": ["email", "password_hash", "nama", "role", "nidn", "prodi", "is_active"],
      "roles": ["superadmin", "kaprodi", "dosen"]
    },
    "Mahasiswa": {
      "collection": "mahasiswa",
      "fields": ["nim", "nama", "email", "password_hash", "prodi", "angkatan", "pembimbing_1_id", "pembimbing_2_id", "reviewer_id", "onboarding_status", "ttu_status"],
      "relationships": "has_many:PembimbingRequest, has_many:Submission"
    },
    "PembimbingRequest": {
      "collection": "pembimbing_requests",
      "types": ["initial", "change"],
      "statuses": ["pending", "approved", "rejected"]
    },
    "Submission": {
      "collection": "submissions",
      "ttu_types": ["ttu_1", "ttu_2", "ttu_3"]
    }
  },

