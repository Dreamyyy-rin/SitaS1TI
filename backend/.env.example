# Flask secret key for session signing
SECRET_KEY=dev-secret-change-me

# MongoDB Connection (pilih salah satu):

# Opsi 1: MongoDB Atlas (Recommended)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/sita?retryWrites=true&w=majority

# Opsi 2: MongoDB Lokal (tanpa auth)
MONGO_URI=mongodb://localhost:27017/sita

# Opsi 3: MongoDB Lokal (dengan auth)
# MONGO_URI=mongodb://admin:password@localhost:27017/sita?authSource=admin

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Flask debug mode (True/False)
FLASK_DEBUG=True
