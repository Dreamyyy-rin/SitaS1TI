# ============================================================
# SITA S1 TI - Environment Variables
# Salin file ini ke .env lalu sesuaikan nilainya
# ============================================================

# --- MongoDB ---
MONGO_USERNAME=admin
MONGO_PASSWORD=ganti-password-ini

# --- Backend ---
# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ganti-secret-key-ini

# CORS: URL yang boleh akses API (URL frontend Anda)
CORS_ORIGINS=http://localhost

# --- Port ---
# Port yang dibuka ke luar (default: 80)
PORT=80
